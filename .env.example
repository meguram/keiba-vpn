# keiba-vpn 環境変数テンプレート
# .env にコピーして値を設定してください: cp .env.example .env
#
# Jupyter 等で既定以外のファイルを読む場合（utils.project_env.load_project_dotenv が参照）
# KEIBA_DOTENV_PATH=/absolute/path/to/.env.local

# --- netkeiba.com ---
# プレミアム契約アカウント（db レース結果の馬別通過・全頭ラップ等に必須）
netkeiba_id=your_email@example.com
netkeiba_pw=your_password
# 起動時・db レース結果取得前のログイン試行（既定 1 = ON）。オフにする場合のみ 0
NETKEIBA_AUTO_LOGIN=1

# ランタイム負荷の上書き: data/queue/queue_load_settings.json（.env より優先。再起動不要。GET/POST /api/scrape-queue/load-settings）
# 同時ジョブ・stagger・ETA表示用秒・netkeiba 同時 in-flight など
# スクレイピングキュー process_queue が同時に処理するジョブ数（馬1頭=1ジョブを最大 N 件並列、1〜32、未設定時は既定 6。IPブロック多いなら 4 推奨）
# SCRAPE_QUEUE_PARALLEL=6
# 一括起動ジョブの開始をずらす（秒×バッチ内インデックス。既定 0.25）
# SCRAPE_QUEUE_STAGGER_SEC=0.25
# キューリーダー process のみ: 失敗ジョブを全件待機に戻し、完了レコードをキューから除去する間隔（秒。既定 3600、0=無効）
# SCRAPE_QUEUE_HOURLY_MAINTENANCE_SEC=3600
# キュー「終了の目安」の粗い計算用：1ジョブあたりの想定秒（既定 10）。実測に合わせて調整。
# SCRAPE_QUEUE_ETA_SEC_PER_JOB=10
# プロセス全体で「netkeiba への同時 in-flight GET」上限（各ジョブが別 Session のため要）。未指定時は並列度から 2〜4 程度に自動。0=制限なし
# NETKEIBA_MAX_CONCURRENT_REQUESTS=3
# netkeiba 同一Sessionのurllib3同時接続数（未設定時は SCRAPE_QUEUE_PARALLEL+4 前後。旧5固定だと並列が5本程度で頭打ち）
# NETKEIBA_HTTP_POOL_MAXSIZE=20
# リクエスト間隔（秒）— ブロック多いなら 2.5 / 4.5 程度に
# NETKEIBA_THROTTLE_MIN=2.2
# NETKEIBA_THROTTLE_MAX=4.0
# キュー投入時に overwrite を省略したジョブの既定。1/true なら常に上書き再取得（smart_skip 相当をオフ）
# （ジョブ JSON の overwrite や API の overwrite で上書き可）
# SCRAPE_DEFAULT_OVERWRITE=0

# --- logs/ 保持（API 起動時スレッド: 毎日 12:00 JST ・mtime が保持日数を超えた logs/*.log を削除） ---
# LOGS_RETENTION_DAYS=7
# LOGS_RETENTION_HOUR_JST=12
# LOGS_RETENTION_MINUTE_JST=0
# LOGS_RETENTION_DISABLED=0

# --- GCS (Google Cloud Storage) ---
GCS_BUCKET=your-bucket-name
GCS_PREFIX=keiba
GCS_TYPE=service_account
GCS_PROJECT_ID=your-project-id
GCS_PRIVATE_KEY_ID=
GCS_PRIVATE_KEY=
GCS_CLIENT_EMAIL=
GCS_CLIENT_ID=
GCS_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCS_TOKEN_URI=https://oauth2.googleapis.com/token
GCS_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCS_CLIENT_CERT_URL=
GCS_UNIVERSE_DOMAIN=googleapis.com

# --- ped_tbl（馬単位血統 Parquet）---
# 出馬表 race_shutuba 保存成功後、ローカル horse_pedigree_5gen から欠損 ped_tbl のみ生成（1=有効）
# KEIBA_SYNC_PED_TBL_ON_SHUTUBA=1
# ped_tbl 生成時に 5 世代目種牡馬接木（未設定時は 1）
# KEIBA_PED_TBL_MERGE_GEN5=1

# --- 開発者認証 ---
DEV_PASSWORD=your-dev-password
DEV_SECRET_KEY=your-secret-key
